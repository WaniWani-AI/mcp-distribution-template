{
  "name": "mcp-distribution",
  "version": "0.0.1",
  "description": "An opinionated MCP Distribution Template from WaniWani AI",
  "type": "module",
  "scripts": {
    "dev": "skybridge dev",
    "start": "skybridge start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "build:alpic": "skybridge build",
    "build:vercel": "skybridge build && mkdir -p public && cp -r dist/assets public/assets"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@waniwani/sdk": "^0.11.1",
    "dotenv": "^17.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "skybridge": ">=0.35.14 <1.0.0",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@skybridge/devtools": ">=0.35.14 <1.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "alpic": "^1.104.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}